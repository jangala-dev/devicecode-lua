          "max_station_diff": 1
        },
        "neighbor_reports": {
          "dyn_report_num": 2,
          "disassoc_report_len": 6
        },
        "legacy": {
          "eval_probe_req": true,
          "eval_assoc_req": false,
          "eval_auth_req": false,
          "min_probe_count": 2,
          "deny_auth_reason": 1,
          "deny_assoc_reason": 17
